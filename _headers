# Cloudflare Pages headers — caching rules (mirror of vercel.json).
# Cloudflare consumes this file at deploy time; it is not served to users.

# Service worker must NEVER be cached, so updates roll out immediately.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML + runtime config always revalidate, so a new ?v= cache-bust is picked up
# on the next load instead of being served stale from the edge.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/config.js
  Cache-Control: no-cache
/config.local.js
  Cache-Control: no-cache

# Vendored libraries are content-stable — cache hard for a year.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# ES modules — explicit MIME avoids strict-module failures on some edge configs.
/js/*
  Content-Type: application/javascript; charset=utf-8
/vendor/*.mjs
  Content-Type: application/javascript; charset=utf-8
/vendor/**/*.mjs
  Content-Type: application/javascript; charset=utf-8
